package pages

import "github.com/seanbman/cbt-dbt-app/internal/views"

templ CheckIn() {
	@views.Layout("Check-in") {
		<section class="content-card">
			<p class="eyebrow">Planned for a later phase</p>
			<h1>Find an exercise</h1>
			<p>A future short private check-in will help suggest a suitable exercise. Answers will remain in your browser and will not be sent to the server.</p>
			<a class="button secondary" href="/exercises">Browse the exercise library</a>
		</section>
	}
}
