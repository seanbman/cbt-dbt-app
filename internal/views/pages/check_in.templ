package pages

import "github.com/seanbman/cbt-dbt-app/internal/views"

templ CheckIn() {
	@views.Layout("Check-in") {
		<section class="content-card">
			<p class="eyebrow">Coming in Phase 1</p>
			<h1>Find an exercise</h1>
			<p>A short private check-in will help suggest a suitable exercise. Answers will remain in your browser and will not be sent to the server.</p>
		</section>
	}
}
