package pages

import "github.com/seanbman/cbt-dbt-app/internal/views"

templ About() {
	@views.Layout("About") {
		<section class="content-card">
			<h1>About this toolbox</h1>
			<p>Steady Steps is a self-guided toolbox with CBT-based, DBT-informed, SMART Recovery-inspired, and recovery-focused exercises. It is not a clinical portal, diagnostic tool, crisis service, or replacement for professional care.</p>
		</section>
	}
}
