package pages

import "github.com/seanbman/cbt-dbt-app/internal/views"

templ Exercises() {
	@views.Layout("Exercises") {
		<section class="content-card">
			<p class="eyebrow">Exercise library</p>
			<h1>Browse exercises</h1>
			<p>The searchable exercise library will be added in a later phase.</p>
		</section>
	}
}
